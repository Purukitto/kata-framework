{
  "name": "@kata-framework/core",
  "version": "0.5.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugins/analytics": {
      "types": "./dist/src/plugins/analytics.d.ts",
      "import": "./dist/src/plugins/analytics.js",
      "require": "./dist/src/plugins/analytics.cjs"
    },
    "./plugins/profanity": {
      "types": "./dist/src/plugins/profanity.d.ts",
      "import": "./dist/src/plugins/profanity.js",
      "require": "./dist/src/plugins/profanity.cjs"
    },
    "./plugins/auto-save": {
      "types": "./dist/src/plugins/auto-save.d.ts",
      "import": "./dist/src/plugins/auto-save.js",
      "require": "./dist/src/plugins/auto-save.cjs"
    },
    "./plugins/logger": {
      "types": "./dist/src/plugins/logger.d.ts",
      "import": "./dist/src/plugins/logger.js",
      "require": "./dist/src/plugins/logger.cjs"
    },
    "./plugins/content-warnings": {
      "types": "./dist/src/plugins/content-warnings.d.ts",
      "import": "./dist/src/plugins/content-warnings.js",
      "require": "./dist/src/plugins/content-warnings.cjs"
    },
    "./plugins/validate": {
      "types": "./dist/src/plugins/validate.d.ts",
      "import": "./dist/src/plugins/validate.js",
      "require": "./dist/src/plugins/validate.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.2.1",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4",
    "gray-matter": "^4.0.3",
    "immer": "^11.1.3",
    "nanoid": "^5.1.6",
    "remark-directive": "^4.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  }
}
