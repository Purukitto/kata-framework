{
  "name": "kata-vscode",
  "displayName": "Kata Language Support",
  "description": "Syntax highlighting for .kata narrative files",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "scripts": {
    "build": "echo 'no build step'",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "categories": ["Programming Languages"],
  "devDependencies": {
    "@vscode/vsce": "^3.5.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "kata",
        "aliases": ["Kata", "kata"],
        "extensions": [".kata"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kata",
        "scopeName": "source.kata",
        "path": "./syntaxes/kata.tmLanguage.json"
      }
    ]
  }
}
